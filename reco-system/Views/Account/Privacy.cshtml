@{
    ViewData["Title"] = "Privacy & Legal";
}

<div class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="text-4xl font-black font-headline text-white mb-2">Privacy & Legal</h1>
    <p class="text-white/40 text-sm mb-10">How we handle your data</p>

    <div class="space-y-6">
        <div class="bg-white/[0.03] border border-white/10 rounded-2xl p-6">
            <h2 class="text-white font-semibold text-lg mb-3">Data We Collect</h2>
            <p class="text-white/50 text-sm leading-relaxed">We collect your name, email address, and content preferences to personalize your experience on Reco-System. We do not sell your data to third parties.</p>
        </div>

        <div class="bg-white/[0.03] border border-white/10 rounded-2xl p-6">
            <h2 class="text-white font-semibold text-lg mb-3">How We Use Your Data</h2>
            <p class="text-white/50 text-sm leading-relaxed">Your data is used solely to provide and improve our recommendation services. Preferences such as favorite genre and language help us show you more relevant content.</p>
        </div>

        <div class="bg-white/[0.03] border border-white/10 rounded-2xl p-6">
            <h2 class="text-white font-semibold text-lg mb-3">Your Rights</h2>
            <p class="text-white/50 text-sm leading-relaxed">You can update or delete your account at any time through the Settings page. For data deletion requests, contact us at privacy@reco-system.com.</p>
        </div>

        <div class="bg-white/[0.03] border border-white/10 rounded-2xl p-6">
            <h2 class="text-white font-semibold text-lg mb-3">Terms of Service</h2>
            <p class="text-white/50 text-sm leading-relaxed">By using Reco-System, you agree to use the platform responsibly. Content added must respect copyright laws. We reserve the right to remove content that violates our guidelines.</p>
        </div>
    </div>
</div>