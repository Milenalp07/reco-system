@{
    ViewData["Title"] = "Subscription";
}

<div class="max-w-4xl mx-auto px-6 py-16">
    <h1 class="text-4xl font-black font-headline text-white mb-2">Subscription</h1>
    <p class="text-white/40 text-sm mb-10">Choose the plan that works for you</p>

    @if (TempData["Success"] != null)
    {
        <div class="mb-6 bg-green-900/20 border border-green-500/30 text-green-400 rounded-xl px-4 py-3 text-sm">
            ✅ @TempData["Success"]
        </div>
    }

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Free -->
        <div class="bg-white/[0.03] border @(ViewBag.CurrentPlan == "Free" ? "border-white/40" : "border-white/10") rounded-2xl p-8">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-white text-2xl font-bold">Free</h2>
                @if (ViewBag.CurrentPlan == "Free")
                {
                    <span class="text-xs uppercase tracking-widest bg-white/10 text-white/60 px-3 py-1 rounded-full">Current Plan</span>
                }
            </div>
            <p class="text-4xl font-black text-white mb-1">$0<span class="text-white/30 text-lg font-normal">/mo</span></p>
            <p class="text-white/40 text-sm mb-6">Browse content only</p>
            <ul class="space-y-3 text-sm text-white/60 mb-8">
                <li class="flex items-center gap-2">✅ Browse books & movies</li>
                <li class="flex items-center gap-2">✅ Search content</li>
                <li class="flex items-center gap-2 text-white/30">❌ Add books</li>
                <li class="flex items-center gap-2 text-white/30">❌ Add movies</li>
                <li class="flex items-center gap-2 text-white/30">❌ Similar recommendations</li>
            </ul>
        </div>

        <!-- Premium -->
        <div class="bg-violet-900/20 border @(ViewBag.CurrentPlan == "Premium" ? "border-violet-400" : "border-violet-500/30") rounded-2xl p-8 relative overflow-hidden">
            <div class="absolute top-4 right-4 text-xs uppercase tracking-widest bg-violet-600 text-white px-3 py-1 rounded-full">Best Value</div>
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-white text-2xl font-bold">Premium</h2>
                @if (ViewBag.CurrentPlan == "Premium")
                {
                    <span class="text-xs uppercase tracking-widest bg-violet-600/30 text-violet-400 px-3 py-1 rounded-full">Current Plan</span>
                }
            </div>
            <p class="text-4xl font-black text-white mb-1">$9.99<span class="text-white/30 text-lg font-normal">/mo</span></p>
            <p class="text-white/40 text-sm mb-6">Full access to everything</p>
            <ul class="space-y-3 text-sm text-white/60 mb-8">
                <li class="flex items-center gap-2">✅ Browse books & movies</li>
                <li class="flex items-center gap-2">✅ Search content</li>
                <li class="flex items-center gap-2">✅ Add books</li>
                <li class="flex items-center gap-2">✅ Add movies</li>
                <li class="flex items-center gap-2">✅ Similar recommendations</li>
            </ul>

            @if (ViewBag.CurrentPlan != "Premium")
            {
                <form asp-action="Upgrade" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="w-full bg-violet-600 hover:bg-violet-700 py-3 rounded-xl text-white font-semibold tracking-wide transition">
                        Upgrade to Premium
                    </button>
                </form>
            }
            else
            {
                <div class="w-full text-center py-3 rounded-xl border border-violet-500/30 text-violet-400 text-sm">
                    ✅ You are Premium!
                </div>
            }
        </div>
    </div>
</div>