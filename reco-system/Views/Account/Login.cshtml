@model reco_system.Models.LoginViewModel
@{ Layout = null; }

<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <title>Login – RecoSystem</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: #0a0a0f; }
        .font-headline { font-family: 'Bebas Neue', sans-serif; }
        .glass { background: rgba(255,255,255,0.04); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.08); }
        .btn-primary { background: linear-gradient(135deg, #7c3aed, #4f46e5); transition: opacity 0.2s; }
        .btn-primary:hover { opacity: 0.85; }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-md">
        <div class="text-center mb-10">
            <h1 class="font-headline text-6xl text-white tracking-wider">RECO</h1>
            <p class="text-white/30 text-sm mt-1 tracking-widest uppercase">Recommendation System</p>
        </div>

        <div class="glass rounded-2xl p-8">
            <h2 class="text-white text-xl font-semibold mb-6">Entrar na conta</h2>

            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-red-400 text-sm mb-4 bg-red-900/20 rounded-lg p-3"></div>

                <div class="mb-4">
                    <label class="text-white/50 text-xs uppercase tracking-widest block mb-2">Email</label>
                    <input asp-for="Email" type="email" placeholder="email@exemplo.com"
                           class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-white/20 focus:outline-none focus:border-violet-500 transition" />
                </div>

                <div class="mb-6">
                    <label class="text-white/50 text-xs uppercase tracking-widest block mb-2">Password</label>
                    <input asp-for="Password" type="password" placeholder="••••••"
                           class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-white/20 focus:outline-none focus:border-violet-500 transition" />
                </div>

                <button type="submit" class="btn-primary w-full py-3 rounded-xl text-white font-semibold text-sm tracking-wide">
                    Entrar
                </button>
            </form>

            <div class="mt-6 p-4 rounded-xl bg-white/[0.03] border border-white/5 text-xs text-white/30 space-y-1">
                <p>🔑 <span class="text-white/50">Admin:</span> admin@reco.com / admin123</p>
                <p>👤 <span class="text-white/50">User:</span> user@reco.com / user123</p>
            </div>
        </div>
    </div>
</body>
</html>