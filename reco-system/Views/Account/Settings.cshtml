@model reco_system.Models.SettingsViewModel
@{
    ViewData["Title"] = "Settings";
}

<div class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="text-4xl font-black font-headline text-white mb-2">Settings</h1>
    <p class="text-white/40 text-sm mb-10">Manage your account and preferences</p>

    @if (TempData["Success"] != null)
    {
        <div class="mb-6 bg-green-900/20 border border-green-500/30 text-green-400 rounded-xl px-4 py-3 text-sm">
            ✅ @TempData["Success"]
        </div>
    }

    <form asp-action="Settings" method="post">
        <div asp-validation-summary="ModelOnly" class="text-red-400 text-sm mb-6 bg-red-900/20 rounded-xl p-4"></div>

        <!-- Profile -->
        <div class="bg-white/[0.03] border border-white/10 rounded-2xl p-6 mb-6">
            <h2 class="text-white font-semibold text-lg mb-5">Profile</h2>

            <div class="mb-4">
                <label class="text-white/50 text-xs uppercase tracking-widest block mb-2">Full Name</label>
                <input asp-for="FullName" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-violet-500 transition" />
            </div>

            <div class="mb-4">
                <label class="text-white/50 text-xs uppercase tracking-widest block mb-2">Email</label>
                <input asp-for="Email" disabled class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white/40 cursor-not-allowed" />
            </div>

            <div class="mb-4">
                <label class="text-white/50 text-xs uppercase tracking-widest block mb-2">Avatar URL</label>
                <input asp-for="AvatarUrl" placeholder="https://..." class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-white/20 focus:outline-none focus:border-violet-500 transition" />
            </div>
        </div>

        <!-- Preferences -->
        <div class="bg-white/[0.03] border border-white/10 rounded-2xl p-6 mb-6">
            <h2 class="text-white font-semibold text-lg mb-5">Preferences</h2>

            <div class="mb-4">
                <label class="text-white/50 text-xs uppercase tracking-widest block mb-2">Favorite Genre</label>
                <select asp-for="FavoriteGenre" class="w-full bg-[#1b1b1b] border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-violet-500 transition">
                    <option value="">Select a genre</option>
                    <option value="Action">Action</option>
                    <option value="Comedy">Comedy</option>
                    <option value="Drama">Drama</option>
                    <option value="Fantasy">Fantasy</option>
                    <option value="Horror">Horror</option>
                    <option value="Romance">Romance</option>
                    <option value="Sci-Fi">Sci-Fi</option>
                    <option value="Thriller">Thriller</option>
                </select>
            </div>

            <div class="mb-4">
                <label class="text-white/50 text-xs uppercase tracking-widest block mb-2">Preferred Language</label>
                <select asp-for="PreferredLanguage" class="w-full bg-[#1b1b1b] border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-violet-500 transition">
                    <option value="English">English</option>
                    <option value="Portuguese">Portuguese</option>
                    <option value="Spanish">Spanish</option>
                    <option value="French">French</option>
                </select>
            </div>
        </div>

        <!-- Change Password -->
        <div class="bg-white/[0.03] border border-white/10 rounded-2xl p-6 mb-6">
            <h2 class="text-white font-semibold text-lg mb-5">Change Password</h2>

            <div class="mb-4">
                <label class="text-white/50 text-xs uppercase tracking-widest block mb-2">Current Password</label>
                <input asp-for="CurrentPassword" type="password" placeholder="••••••" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-white/20 focus:outline-none focus:border-violet-500 transition" />
            </div>

            <div class="mb-4">
                <label class="text-white/50 text-xs uppercase tracking-widest block mb-2">New Password</label>
                <input asp-for="NewPassword" type="password" placeholder="••••••" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-white/20 focus:outline-none focus:border-violet-500 transition" />
            </div>

            <div>
                <label class="text-white/50 text-xs uppercase tracking-widest block mb-2">Confirm New Password</label>
                <input asp-for="ConfirmNewPassword" type="password" placeholder="••••••" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-white/20 focus:outline-none focus:border-violet-500 transition" />
            </div>
        </div>

        <button type="submit" class="w-full bg-violet-600 hover:bg-violet-700 py-3 rounded-xl text-white font-semibold tracking-wide transition">
            Save Changes
        </button>
    </form>
</div>