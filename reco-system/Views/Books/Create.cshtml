@model reco_system.Models.Book
@{
    ViewData["Title"] = "Adicionar Livro";
}

<div class="max-w-2xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-black font-headline text-white mb-8">Adicionar Livro</h1>

    <div class="bg-white/5 border border-white/10 rounded-2xl p-8">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-red-400 text-sm mb-4 bg-red-900/20 rounded-lg p-3"></div>

            <div class="mb-5">
                <label class="text-white/50 text-xs uppercase tracking-widest block mb-2">Título</label>
                <input asp-for="Title" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-white/20 focus:outline-none focus:border-violet-500 transition" />
            </div>

            <div class="mb-5">
                <label class="text-white/50 text-xs uppercase tracking-widest block mb-2">Autor</label>
                <input asp-for="Author" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-white/20 focus:outline-none focus:border-violet-500 transition" />
            </div>

            <div class="mb-5">
                <label class="text-white/50 text-xs uppercase tracking-widest block mb-2">Género</label>
                <input asp-for="Genre" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-white/20 focus:outline-none focus:border-violet-500 transition" />
            </div>

            <div class="mb-5">
                <label class="text-white/50 text-xs uppercase tracking-widest block mb-2">Ano de Publicação</label>
                <input asp-for="YearPublished" type="number" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-white/20 focus:outline-none focus:border-violet-500 transition" />
            </div>

            <div class="mb-5">
                <label class="text-white/50 text-xs uppercase tracking-widest block mb-2">Descrição</label>
                <textarea asp-for="Description" rows="4" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-white/20 focus:outline-none focus:border-violet-500 transition"></textarea>
            </div>

            <div class="mb-5">
                <label class="text-white/50 text-xs uppercase tracking-widest block mb-2">Rating (0-5)</label>
                <input asp-for="Rating" type="number" step="0.1" min="0" max="5" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-white/20 focus:outline-none focus:border-violet-500 transition" />
            </div>

            <div class="mb-8">
                <label class="text-white/50 text-xs uppercase tracking-widest block mb-2">URL da Imagem</label>
                <input asp-for="ImageUrl" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-white/20 focus:outline-none focus:border-violet-500 transition" />
            </div>

            <div class="flex gap-4">
                <button type="submit" class="flex-1 bg-violet-600 hover:bg-violet-700 py-3 rounded-xl text-white font-semibold tracking-wide transition">
                    Guardar Livro
                </button>
                <a asp-action="Index" class="flex-1 text-center border border-white/20 py-3 rounded-xl text-white/60 hover:text-white hover:border-white/40 transition">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>