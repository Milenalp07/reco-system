@model reco_system.Services.TmdbMovieDetails
@using System.Reflection

@functions {
    public static string GetStringProp(object obj, params string[] names)
    {
        if (obj == null) return "";

        var type = obj.GetType();

        foreach (var name in names)
        {
            var prop = type.GetProperty(name, BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);
            if (prop != null)
            {
                var value = prop.GetValue(obj);
                return value?.ToString() ?? "";
            }
        }

        return "";
    }

    public static double GetDoubleProp(object obj, params string[] names)
    {
        if (obj == null) return 0;

        var type = obj.GetType();

        foreach (var name in names)
        {
            var prop = type.GetProperty(name, BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);
            if (prop != null)
            {
                var value = prop.GetValue(obj);
                if (value == null) return 0;

                if (double.TryParse(value.ToString(), out var result))
                    return result;
            }
        }

        return 0;
    }

    public static int GetIntProp(object obj, params string[] names)
    {
        if (obj == null) return 0;

        var type = obj.GetType();

        foreach (var name in names)
        {
            var prop = type.GetProperty(name, BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);
            if (prop != null)
            {
                var value = prop.GetValue(obj);
                if (value == null) return 0;

                if (int.TryParse(value.ToString(), out var result))
                    return result;
            }
        }

        return 0;
    }
}

@{
    ViewData["Title"] = Model.Title;

    var posterUrl = !string.IsNullOrEmpty(Model.Poster_Path)
        ? $"https://image.tmdb.org/t/p/w500{Model.Poster_Path}"
        : "https://via.placeholder.com/500x750?text=No+Image";

    var backdropUrl = !string.IsNullOrEmpty(Model.Backdrop_Path)
        ? $"https://image.tmdb.org/t/p/original{Model.Backdrop_Path}"
        : posterUrl;

    var genres = Model.Genres != null && Model.Genres.Any()
        ? string.Join(", ", Model.Genres.Select(g => g.Name))
        : "No genre";

    var year = !string.IsNullOrEmpty(Model.Release_Date) && Model.Release_Date.Length >= 4
        ? Model.Release_Date.Substring(0, 4)
        : "N/A";

    var similar = ViewBag.Similar as IEnumerable<object> ?? new List<object>();
}

<section class="relative min-h-screen text-white">
    <div class="absolute inset-0">
        <img src="@backdropUrl" alt="@Model.Title" class="w-full h-full object-cover opacity-20" />
        <div class="absolute inset-0 bg-black/80"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-[#131313] via-[#131313]/80 to-black/70"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 py-16">
        <a href="/" class="inline-flex items-center gap-2 text-white/70 hover:text-white mb-10 transition">
            <span>←</span>
            <span>Back to search</span>
        </a>

        <div class="grid grid-cols-1 lg:grid-cols-[340px_1fr] gap-10 items-start">
            <div class="rounded-3xl overflow-hidden shadow-2xl bg-black/30">
                <img src="@posterUrl" alt="@Model.Title" class="w-full h-auto object-cover" />
            </div>

            <div class="pt-2">
                <p class="text-[11px] uppercase tracking-[0.35em] text-white/40 mb-4">
                    TMDB Movie Details
                </p>

                <h1 class="font-headline text-4xl md:text-6xl font-black tracking-tight text-white mb-4">
                    @Model.Title
                </h1>

                <div class="flex flex-wrap items-center gap-3 text-sm text-white/70 mb-6">
                    <span class="px-3 py-1 rounded-full bg-white/10 border border-white/10">
                        ⭐ @Model.Vote_Average.ToString("0.0")
                    </span>
                    <span class="px-3 py-1 rounded-full bg-white/10 border border-white/10">
                        @year
                    </span>
                    <span class="px-3 py-1 rounded-full bg-white/10 border border-white/10">
                        @(Model.Runtime > 0 ? $"{Model.Runtime} min" : "Runtime N/A")
                    </span>
                </div>

                <p class="text-white/50 uppercase tracking-[0.2em] text-xs mb-2">
                    Genres
                </p>
                <p class="text-white text-base mb-8">
                    @genres
                </p>

                <p class="text-white/50 uppercase tracking-[0.2em] text-xs mb-2">
                    Overview
                </p>
                <p class="text-white/80 text-base leading-8 max-w-3xl mb-10">
                    @(string.IsNullOrWhiteSpace(Model.Overview) ? "No description available." : Model.Overview)
                </p>

                <div class="flex flex-col sm:flex-row gap-4">
                    <button class="px-8 py-4 bg-white text-black font-headline text-xs font-black uppercase tracking-widest rounded-full hover:scale-105 transition">
                        Add to Library
                    </button>

                    <a href="/" class="px-8 py-4 border border-white/20 text-white font-headline text-xs font-black uppercase tracking-widest rounded-full hover:bg-white/5 transition text-center">
                        Back
                    </a>
                </div>
            </div>
        </div>

        <div class="mt-16">
            <h2 class="text-2xl lg:text-3xl font-bold mb-6">Similar Movies</h2>

            @if (similar.Any())
            {
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                    @foreach (var movie in similar)
                    {
                        var movieId = GetIntProp(movie, "Id", "id");
                        var movieTitle = GetStringProp(movie, "Title", "title", "Name", "name");
                        var moviePosterPath = GetStringProp(movie, "Poster_Path", "poster_path", "PosterPath", "posterPath");
                        var movieReleaseDate = GetStringProp(movie, "Release_Date", "release_date", "ReleaseDate", "releaseDate");
                        var movieVoteAverage = GetDoubleProp(movie, "Vote_Average", "vote_average", "VoteAverage", "voteAverage");

                        var similarPoster = !string.IsNullOrEmpty(moviePosterPath)
                            ? $"https://image.tmdb.org/t/p/w500{moviePosterPath}"
                            : "https://via.placeholder.com/500x750?text=No+Image";

                        var similarYear = !string.IsNullOrEmpty(movieReleaseDate) && movieReleaseDate.Length >= 4
                            ? movieReleaseDate.Substring(0, 4)
                            : "N/A";

                        <a href="/Movies/TmdbDetails/@movieId" class="block group">
                            <div class="relative overflow-hidden rounded-3xl bg-white/5 border border-white/10 shadow-xl">
                                <img src="@similarPoster"
                                     alt="@movieTitle"
                                     class="w-full h-[420px] object-cover group-hover:scale-105 transition duration-300" />

                                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>

                                <div class="absolute bottom-0 left-0 right-0 p-5">
                                    <div class="flex items-center justify-between gap-3 mb-2">
                                        <span class="text-[11px] uppercase tracking-[0.2em] text-white/60">
                                            @similarYear
                                        </span>
                                        <span class="px-2 py-1 rounded-full bg-white/10 text-xs font-semibold text-white">
                                            ⭐ @movieVoteAverage.ToString("0.0")
                                        </span>
                                    </div>

                                    <h3 class="text-lg font-bold text-white leading-snug">
                                        @movieTitle
                                    </h3>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="bg-white/5 border border-white/10 rounded-3xl p-6 text-white/50">
                    No similar movies found.
                </div>
            }
        </div>
    </div>
</section>