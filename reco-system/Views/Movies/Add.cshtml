@{
    ViewData["Title"] = "Add Movie";
}

<div class="max-w-3xl mx-auto px-6 py-16">
    <div class="mb-8">
        <a asp-controller="Home" asp-action="Index" class="text-white/40 text-xs uppercase tracking-widest hover:text-white transition flex items-center gap-2">
            <span class="material-symbols-outlined text-sm">arrow_back</span> Back
        </a>
        <h1 class="text-4xl font-black font-headline text-white mt-4">Add Movie</h1>
        <p class="text-white/40 text-sm mt-1">Search for a movie and select it from the list</p>
    </div>

    <div class="bg-white/[0.03] border border-white/10 rounded-2xl p-8 mb-8">
        <label class="text-white/50 text-xs uppercase tracking-widest block mb-3">Search Movie</label>
        <div class="flex gap-3">
            <input id="movieSearch" type="text" placeholder="Ex: Batman, Inception, Avatar..."
                   class="flex-1 bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-white/20 focus:outline-none focus:border-violet-500 transition" />
            <button onclick="searchMovie()" class="bg-violet-600 hover:bg-violet-700 px-6 py-3 rounded-xl text-white font-semibold transition">
                Search
            </button>
        </div>
    </div>

    <div id="results" class="hidden">
        <h2 class="text-white/50 text-xs uppercase tracking-widest mb-4">Select a movie</h2>
        <div id="resultsGrid" class="grid grid-cols-2 md:grid-cols-3 gap-4"></div>
    </div>

    <div id="selectedMovie" class="hidden mt-8 bg-white/[0.03] border border-violet-500/30 rounded-2xl p-6">
        <h2 class="text-white/50 text-xs uppercase tracking-widest mb-4">Selected Movie</h2>
        <div class="flex gap-6 items-start">
            <img id="selectedPoster" src="" class="w-24 rounded-xl" />
            <div>
                <h3 id="selectedTitle" class="text-white text-xl font-bold"></h3>
                <p id="selectedRating" class="text-white/50 text-sm mt-1"></p>
                <a id="selectedLink" href="#" class="inline-block mt-4 bg-violet-600 hover:bg-violet-700 px-6 py-2 rounded-xl text-white text-sm font-semibold transition">
                    View Details & Similar →
                </a>
            </div>
        </div>
    </div>
</div>

<script>
    async function searchMovie() {
        const query = document.getElementById('movieSearch').value.trim();
        if (!query) return;

        const res = await fetch(`/api/tmdb/search?query=${encodeURIComponent(query)}`);
        const movies = await res.json();

        const grid = document.getElementById('resultsGrid');
        grid.innerHTML = '';

        movies.slice(0, 9).forEach(movie => {
            const poster = movie.imageUrl
                ? `<img src="${movie.imageUrl}" class="w-full h-48 object-cover" />`
                : `<div class="w-full h-48 bg-white/5 flex items-center justify-center text-white/20 text-xs">No image</div>`;

            grid.innerHTML += `
                <div onclick="selectMovie(${movie.id}, '${movie.title.replace(/'/g, "\\'")}', '${movie.imageUrl || ''}', ${movie.rating})"
                     class="cursor-pointer bg-white/5 border border-white/10 hover:border-violet-500 rounded-xl overflow-hidden transition group">
                    ${poster}
                    <div class="p-3">
                        <p class="text-white text-sm font-semibold group-hover:text-violet-400 transition">${movie.title}</p>
                        <p class="text-white/40 text-xs mt-1">⭐ ${movie.rating.toFixed(1)}</p>
                    </div>
                </div>`;
        });

        document.getElementById('results').classList.remove('hidden');
    }

    function selectMovie(id, title, imageUrl, rating) {
        document.getElementById('selectedTitle').textContent = title;
        document.getElementById('selectedRating').textContent = `⭐ ${rating.toFixed(1)}`;
        document.getElementById('selectedPoster').src = imageUrl || '';
        document.getElementById('selectedLink').href = `/Movies/TmdbDetails/${id}`;
        document.getElementById('selectedMovie').classList.remove('hidden');
        document.getElementById('selectedMovie').scrollIntoView({ behavior: 'smooth' });
    }

    document.getElementById('movieSearch').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') searchMovie();
    });
</script>