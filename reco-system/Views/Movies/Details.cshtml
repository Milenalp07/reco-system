@model reco_system.Models.Movie

<h1>@Model.Title</h1>

<img src="@Model.ImageUrl" style="width:300px; border-radius:10px;" />

<p><strong>Genre:</strong> @Model.Genre</p>
<p><strong>Year:</strong> @Model.ReleaseYear</p>
<p><strong>Description:</strong> @Model.Description</p>
<p><strong>Rating:</strong> ⭐ @Model.Rating</p>

<a asp-action="Index">Back</a>